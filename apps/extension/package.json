{
  "name": "@contextvault/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build --config vite.config.ts && node scripts/build-extension.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "vite dev --config vite.config.ts",
    "test": "vitest run",
    "verify": "npm run check && npm run test && npm run build"
  },
  "dependencies": {
    "@contextvault/shared": "file:../../packages/shared",
    "fflate": "^0.8.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
